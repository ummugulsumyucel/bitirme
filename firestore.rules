rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar kendi profillerini okuyup yazabilir
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Duyurular, etkinlikler, notlar: herkes okuyabilir, giriş yapan yazabilir
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{docId} {
      allow read: if true;
      // Yeni etkinlik oluşturma: giriş yapmış herkes (yetki kontrolü uygulama katmanında)
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;
      // Güncelleme ve silme: etkinliği oluşturan kişi VEYA createdBy boşsa giriş yapmış herkes
      allow update, delete: if request.auth != null
                             && (resource.data.createdBy == request.auth.uid
                                 || resource.data.createdBy == '');
    }

    match /personal_events/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /notes/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Diğer tüm koleksiyonlar: giriş yapmış herkes okuyup yazabilir
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
