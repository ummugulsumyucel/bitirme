{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (bitirme)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Flutter: Chrome",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}",
      "deviceId": "chrome"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Chrome → localhost:8080 (manuel sunucu)",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
